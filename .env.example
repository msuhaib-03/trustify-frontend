# ========================================================
# TRUSTIFY ENVIRONMENT CONFIGURATION
# ========================================================
# Copy this file to .env.local and update the values
# ========================================================

# API Configuration
# Set to "false" to use real backend, "true" to use mock data
NEXT_PUBLIC_USE_MOCK_API=false

# Backend API URL - Update this to your Spring Boot backend URL
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api

# Stripe publishable key (pk_test_... or pk_live_... from Stripe dashboard)
# REQUIRED for real card payments - get from https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_KEY_HERE

# ========================================================
# IMPORTANT NOTES:
# ========================================================
# 1. The backend must return JWT token on login with structure:
#    {
#      token: "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...",
#      username: "admin",
#      email: "admin@example.com",
#      role: "ADMIN"  // or "USER"
#    }
#
# 2. All admin endpoints require:
#    - Authorization header: "Bearer <token>"
#    - The JWT must contain ADMIN role
#
# 3. Admin endpoints used:
#    - GET /admin/dashboard
#    - GET /admin/users
#    - GET /admin/users/{id}
#    - GET /admin/stats
#    - GET /admin/disputes
#    - GET /admin/users/high-risk
#    - POST /admin/suspend-user/{userId}
#    - GET /admin/cnic/pending
#    - GET /admin/cnic/all
#    - POST /admin/cnic/{id}/approve
#    - POST /admin/cnic/{id}/reject
#
# 4. If getting 403 Forbidden errors, check:
#    - Token is stored in localStorage as "token"
#    - Backend is validating JWT correctly
#    - Backend role check accepts "ADMIN" role
#    - CORS is configured on backend for your frontend URL
# ========================================================
